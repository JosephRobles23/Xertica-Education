GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_API_KEY=your-google-api-key
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.file

# Deep Research: con TAVILY_API_KEY configurada la búsqueda usa Tavily (URLs
# limpias, más rápido); sin ella se cae a Gemini + Google Search Grounding.
# El ranking/detección con Tavily usa OPENROUTER_KEY + RESEARCH_RANK_MODEL.
TAVILY_API_KEY=tvly-your-api-key
RESEARCH_RANK_MODEL=openai/gpt-4o-mini

# ─── Deploy (staging · Opción B) ──────────────────────────────────────────
# Con MODAL_RENDER_APP vacío el render corre in-process (dev local). Con el
# nombre de la app Modal (p.ej. "xertica-render-staging") el API delega el
# render pesado a Modal. Los tokens los lee el SDK de Modal del entorno.
MODAL_RENDER_APP=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
