# Config de la API · copia este archivo a apps/api/.env y rellena los valores.
# apps/api/.env está gitignored — NUNCA commitees secretos reales.

# ── Supabase (ADR-0004) ───────────────────────────────────────────────
# URL del proyecto: https://<project-ref>.supabase.co
SUPABASE_URL=https://placeholder-project.supabase.co
# Key service_role (Settings → API en el dashboard). Solo server-side.
SUPABASE_KEY=placeholder-key

# ── Proveedores de IA / render ────────────────────────────────────────
OPENROUTER_KEY=placeholder-key
VEO_KEY=placeholder-key

# ── Storage ───────────────────────────────────────────────────────────
STORAGE_BUCKET=xertica-education-assets

# ── Modelos por rol funcional (opcional, JSON) ────────────────────────
# MODEL_NAMES={"route_structurer":"gemini-2.5-pro","scriptwriter":"gemini-2.5-pro","infographic_design":"claude-sonnet","researcher":"gemini-2.5-flash"}
