# Config del frontend Next.js · copia a apps/web/.env.local
# Solo variables NEXT_PUBLIC_* llegan al navegador. NUNCA pongas secretos aquí
# (el backend es el único que habla con Supabase — ver ADR-0004).

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=your-google-api-key
NEXT_PUBLIC_GOOGLE_DRIVE_APP_ID=your-google-cloud-project-number
